{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "liotree",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_item"
      }
    },
    "_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "root"
        },
        {
          "type": "SYMBOL",
          "name": "file_entry"
        },
        {
          "type": "SYMBOL",
          "name": "directory_entry"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        }
      ]
    },
    "root": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "root_bar"
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directory_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "root_bar": {
      "type": "STRING",
      "value": "|"
    },
    "entry_bar": {
      "type": "STRING",
      "value": "|"
    },
    "format_space": {
      "type": "PATTERN",
      "value": "\\s"
    },
    "depth_mark": {
      "type": "PATTERN",
      "value": "[-+]"
    },
    "file_entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "entry_bar"
        },
        {
          "type": "FIELD",
          "name": "bridge",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "depth_mark"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "leaf",
          "content": {
            "type": "SYMBOL",
            "name": "depth_mark"
          }
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "file_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "directory_entry": {
      "type": "PREC_LEFT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "SYMBOL",
            "name": "entry_bar"
          },
          {
            "type": "FIELD",
            "name": "bridge",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "REPEAT",
                  "content": {
                    "type": "SYMBOL",
                    "name": "depth_mark"
                  }
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          },
          {
            "type": "FIELD",
            "name": "leaf",
            "content": {
              "type": "SYMBOL",
              "name": "depth_mark"
            }
          },
          {
            "type": "STRING",
            "value": " "
          },
          {
            "type": "FIELD",
            "name": "name",
            "content": {
              "type": "SYMBOL",
              "name": "directory_name"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "contents",
                "content": {
                  "type": "REPEAT1",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_item"
                  }
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "directory_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[^-+|>\\s][^|>\\n]*\\/['\"]{0,1}"
        },
        {
          "type": "FIELD",
          "name": "formatspace",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "format_space"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "file_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^-+|>\\s][^|>\\/\\n\\s]*"
            },
            {
              "type": "PATTERN",
              "value": "\\\"[^|>\\/\\n]*\\\""
            },
            {
              "type": "PATTERN",
              "value": "\\'[^|>\\/\\n]*\\'"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "formatspace",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "format_space"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        }
      ]
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^|\\n]"
              },
              {
                "type": "SYMBOL",
                "name": "comment_newline"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "||"
        }
      ]
    },
    "comment_newline": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\n\\s*"
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "PATTERN",
          "value": "\\s*"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[\\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}