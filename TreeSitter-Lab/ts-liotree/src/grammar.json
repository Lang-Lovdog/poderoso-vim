{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "liotree",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_node"
      }
    },
    "_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "root"
        },
        {
          "type": "SYMBOL",
          "name": "entry"
        }
      ]
    },
    "root": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "root_bar"
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directory_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "root_bar": {
      "type": "STRING",
      "value": "|"
    },
    "entry_bar": {
      "type": "STRING",
      "value": "|"
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "entry_bar"
        },
        {
          "type": "FIELD",
          "name": "bridge",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "REPEAT",
                "content": {
                  "type": "SYMBOL",
                  "name": "depth_mark"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        },
        {
          "type": "FIELD",
          "name": "leaf",
          "content": {
            "type": "SYMBOL",
            "name": "depth_mark"
          }
        },
        {
          "type": "STRING",
          "value": " "
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "directory_name"
              },
              {
                "type": "SYMBOL",
                "name": "file_name"
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "depth_mark": {
      "type": "PATTERN",
      "value": "[-+]"
    },
    "directory_name": {
      "type": "PATTERN",
      "value": "[^-+|>\\s][^|>\\n]*\\/"
    },
    "file_name": {
      "type": "PATTERN",
      "value": "[^-+|>\\s][^|>\\/\\n]*"
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^|\\n]"
              },
              {
                "type": "SYMBOL",
                "name": "comment_newline"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "||"
        }
      ]
    },
    "comment_newline": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\n\\s*"
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "PATTERN",
          "value": "\\s*"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}